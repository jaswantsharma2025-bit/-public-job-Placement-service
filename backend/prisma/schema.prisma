generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  WORKER
  ADMIN
  EMPLOYER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum SkillCategory {
  MAID
  COOK
  DRIVER
  NURSE
  PLUMBER
  ELECTRICIAN
}

enum BookingType {
  INSTANT
  SCHEDULED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

model User {
  id       String @id @default(cuid())
  name     String
  phone    String @unique
  password String

  role Role

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  customerProfile CustomerProfile?
  workerProfile   WorkerProfile?
  employerProfile EmployerProfile?

  customerBookings Booking[] @relation("CustomerBookings")
  workerBookings   Booking[] @relation("WorkerBookings")
  customerReviews Review[] @relation("CustomerReviews")
  workerReviews Review[] @relation("WorkerReviews")
}

model CustomerProfile {
  id     String @id @default(cuid())
  userId String @unique

  gender Gender?

  address String?
  city    String?
  state   String?

  latitude  Float?
  longitude Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model WorkerProfile {
  id String @id @default(cuid())

  userId String @unique

  aadhaarNumber String @unique

  gender Gender?

  skillCategory SkillCategory

  experience Int

  expectedSalary Float

  city  String?
  state String?

  latitude  Float?
  longitude Float?

  isVerified Boolean @default(false)

  isAvailable Boolean @default(true)

  rating Float @default(0)

  totalReviews Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model EmployerProfile {
  id String @id @default(cuid())

  userId String @unique

  companyName String

  contactPerson String

  address String?

  city  String?
  state String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Booking {
  id String @id @default(cuid())

  customerId String
  workerId   String

  customerName  String
  customerPhone String

  workerName  String
  workerPhone String

  bookingType BookingType
  review Review?

  serviceCategory SkillCategory

  address String
  city    String

  scheduledDate DateTime

  durationMinutes Int

  servicePrice Float?

  notes String?

  status BookingStatus @default(PENDING)

  acceptedAt  DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  customer User @relation("CustomerBookings", fields: [customerId], references: [id])

  worker User @relation("WorkerBookings", fields: [workerId], references: [id])

  @@index([customerId])
  @@index([workerId])
  @@index([status])
}

model Review {
  id String @id @default(cuid())

  bookingId String @unique

  customerId String
  workerId String

  rating Int

  comment String?

  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])

  customer User @relation("CustomerReviews", fields: [customerId], references: [id])

worker User @relation("WorkerReviews", fields: [workerId], references: [id])

  @@index([workerId])
}