generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  WORKER
  ADMIN
  EMPLOYER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum EducationLevel {
  NO_FORMAL_EDUCATION
  PRIMARY
  SECONDARY
  HIGHER_SECONDARY
  DIPLOMA
  GRADUATE
  POST_GRADUATE
}

enum SkillCategory {
  MAID
  COOK
  DRIVER
  NURSE
  PLUMBER
  ELECTRICIAN
}

enum BookingType {
  INSTANT
  SCHEDULED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
}

model User {
  id       String @id @default(cuid())
  name     String
  phone    String @unique
  password String

  role Role

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  customerProfile CustomerProfile?
  workerProfile   WorkerProfile?
  employerProfile EmployerProfile?

  customerBookings Booking[] @relation("CustomerBookings")
  workerBookings   Booking[] @relation("WorkerBookings")
  customerReviews  Review[]  @relation("CustomerReviews")
  workerReviews    Review[]  @relation("WorkerReviews")
}

model CustomerProfile {
  id     String @id @default(cuid())
  userId String @unique

  gender Gender?

  address String?
  city    String?
  state   String?

  latitude  Float?
  longitude Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model WorkerProfile {
  id     String @id @default(cuid())
  userId String @unique

  // ── Documents ────────────────────────────────────────────
  aadhaarNumber String  @unique
  profilePhotoUrl String?

  // ── Personal ─────────────────────────────────────────────
  gender        Gender?
  dateOfBirth   DateTime?
  height        Float?          // in cm
  weight        Float?          // in kg
  languagesKnown String[]       // e.g. ["Hindi", "English"]
  education     EducationLevel?
  maritalStatus MaritalStatus?

  // ── Professional ─────────────────────────────────────────
  skillCategory  SkillCategory
  experience     Int
  expectedSalary Float
  aboutYourself  String?
  previousCompanies String?     // free-text / JSON string
  certifications    String?     // free-text / JSON string
  availableTimings  String?     // e.g. "9am – 6pm"
  preferredWorkingRadius Int?   // in km
  canRelocate    Boolean @default(false)

  // ── Family & Emergency ───────────────────────────────────
  fatherName            String?
  motherName            String?
  emergencyContact      String?
  emergencyContactNumber String?

  // ── Location ─────────────────────────────────────────────
  city      String?
  state     String?
  latitude  Float?
  longitude Float?

  // ── Platform fields ──────────────────────────────────────
  isVerified  Boolean @default(false)
  isAvailable Boolean @default(true)
  isSuspended Boolean @default(false)

  rating       Float @default(0)
  totalReviews Int   @default(0)

  verifiedAt       DateTime?
  verifiedBy       String?
  suspensionReason String?
  rejectionReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model EmployerProfile {
  id String @id @default(cuid())

  userId String @unique

  companyName   String
  contactPerson String
  address       String?
  city          String?
  state         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Booking {
  id String @id @default(cuid())

  customerId String
  workerId   String

  customerName  String
  customerPhone String

  workerName  String
  workerPhone String

  bookingType BookingType
  review      Review?

  serviceCategory SkillCategory

  address String
  city    String

  scheduledDate   DateTime
  durationMinutes Int

  servicePrice Float?
  notes        String?

  status BookingStatus @default(PENDING)

  acceptedAt  DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  cancelledAt DateTime?

  workerPayout Float? @default(0)
  platformFee  Float? @default(0)

  isPaidToWorker Boolean @default(false)
  paidAt         DateTime?

  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod String?

  startedByCustomer   Boolean @default(false)
  completedByCustomer Boolean @default(false)

  replacementRequested  Boolean @default(false)
  replacementReason     String?
  replacementWorkerId   String?
  replacementAssignedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  customer   User        @relation("CustomerBookings", fields: [customerId], references: [id])
  worker     User        @relation("WorkerBookings", fields: [workerId], references: [id])
  complaints Complaint[]

  @@index([customerId])
  @@index([workerId])
  @@index([status])
}

model Review {
  id String @id @default(cuid())

  bookingId  String @unique
  customerId String
  workerId   String

  rating  Int
  comment String?

  createdAt DateTime @default(now())

  booking  Booking @relation(fields: [bookingId], references: [id])
  customer User    @relation("CustomerReviews", fields: [customerId], references: [id])
  worker   User    @relation("WorkerReviews", fields: [workerId], references: [id])

  @@index([workerId])
}

enum ComplaintStatus {
  OPEN
  RESOLVED
  REJECTED
}

model Complaint {
  id String @id @default(cuid())

  bookingId      String
  raisedByUserId String
  againstUserId  String

  reason      String
  description String?

  status     ComplaintStatus @default(OPEN)
  adminNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([raisedByUserId])
  @@index([againstUserId])
}
